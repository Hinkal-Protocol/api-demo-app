{
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["es2022", "dom"],
    "useDefineForClassFields": true,
    "allowJs": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "references": [],
  "exclude": ["node_modules"]
}
